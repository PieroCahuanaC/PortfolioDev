---
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>Piero Cahuana - Portfolio | Web Dev & Data Science</title>
    <meta
      name="title"
      content="Piero Cahuana - Portfolio | Web Dev & Data Science"
    />
    <meta
      name="description"
      content="Portfolio profesional de Piero Cahuana, Ingeniero de Sistemas especializado en Desarrollo Web y Ciencia de Datos. Proyectos, experiencia y stack tecnológico."
    />
    <meta
      name="keywords"
      content="portfolio, Piero Cahuana, desarrollo web, ciencia de datos, data science, backend, python, astro"
    />
    <meta name="author" content="Piero Cahuana" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content="https://github.com/PieroCahuanaC/PortfolioDev"
    />
    <meta
      property="og:title"
      content="Piero Cahuana - Portfolio | Web Dev & Data Science"
    />
    <meta
      property="og:description"
      content="Explora el portfolio de Piero Cahuana: Desarrollo web, Ciencia de Datos y soluciones tecnológicas eficientes."
    />
    <meta property="og:image" content="/images/profile/image.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta
      property="twitter:url"
      content="https://github.com/PieroCahuanaC/PortfolioDev"
    />
    <meta
      property="twitter:title"
      content="Piero Cahuana - Portfolio | Web Dev & Data Science"
    />
    <meta
      property="twitter:description"
      content="Explora el portfolio de Piero Cahuana: Desarrollo web, Ciencia de Datos y soluciones tecnológicas eficientes."
    />
    <meta property="twitter:image" content="/images/profile/image.png" />
  </head>
  <body>
    <slot />
    <style>
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
      }
    </style>
  </body>
</html>
