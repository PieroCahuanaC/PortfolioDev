---
// Componente estático — sin JS del lado del cliente
---

<section
  class="min-h-screen flex flex-col justify-center section-padding pt-28 relative overflow-hidden"
>
  <!-- Grid bg -->
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(hsl(172 66% 50%) 1px, transparent 1px), linear-gradient(90deg, hsl(172 66% 50%) 1px, transparent 1px); background-size: 60px 60px;"
  >
  </div>

  <div class="relative max-w-7xl mx-auto w-full">
    <p
      class="font-mono text-primary text-sm mb-2 animate-fade-in-up"
      style="animation-delay: 0.1s;"
    >
      Hola, soy
    </p>
    <h2
      class="font-display text-3xl md:text-5xl font-bold text-foreground mb-4 animate-fade-in-up"
      style="animation-delay: 0.15s;"
    >
      Piero Cahuana
    </h2>
    <h1
      class="font-display text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-[0.95] mb-6 animate-fade-in-up"
      style="animation-delay: 0.2s;"
    >
      Desarrollo Web<br />
      <span class="text-gradient">& Ciencia de Datos</span>
    </h1>
    <p
      class="text-muted-foreground text-lg md:text-xl max-w-xl mb-10 animate-fade-in-up"
      style="animation-delay: 0.35s;"
    >
      Estudiante de último año de Ingeniería de Sistemas. Construyo soluciones
      web y analizo datos con código limpio y atención al detalle.
    </p>

    <div
      class="flex items-center gap-4 animate-fade-in-up"
      style="animation-delay: 0.5s;"
    >
      <a
        href="#proyectos"
        class="inline-flex items-center gap-2 bg-primary text-primary-foreground font-mono text-sm px-6 py-3 rounded-md hover:opacity-90 transition-opacity"
      >
        Ver proyectos
      </a>
      <a
        href="#sobre-mi"
        class="inline-flex items-center gap-2 border border-border text-foreground font-mono text-sm px-6 py-3 rounded-md hover:border-primary/50 transition-colors"
      >
        Sobre mí
      </a>
      <a
        href="https://drive.google.com/file/d/1GR7KO14z45U1kabJGcj-4uL_ffKu65-L/view?usp=sharing"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border border-primary/30 text-primary font-mono text-sm px-6 py-3 rounded-md hover:bg-primary/10 transition-all duration-300"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Descargar CV
      </a>

      <div class="flex items-center gap-3 ml-2">
        <a
          href="https://github.com/PieroCahuanaC"
          target="_blank"
          rel="noopener noreferrer"
          class="p-3 rounded-md border border-border text-muted-foreground hover:text-primary hover:border-primary/50 transition-all duration-300 bg-card/50"
          aria-label="GitHub"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/in/piero-anthony-cahuana-cabrera-57b113323/"
          target="_blank"
          rel="noopener noreferrer"
          class="p-3 rounded-md border border-border text-muted-foreground hover:text-primary hover:border-primary/50 transition-all duration-300 bg-card/50"
          aria-label="LinkedIn"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path>
            <rect width="4" height="12" x="2" y="9"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- ArrowDown icon -->
  <a
    href="#proyectos"
    class="absolute bottom-10 left-1/2 -translate-x-1/2 text-muted-foreground hover:text-primary transition-colors animate-bounce"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M12 5v14"></path>
      <path d="m19 12-7 7-7-7"></path>
    </svg>
  </a>
</section>
