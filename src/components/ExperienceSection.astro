---
const icons: Record<string, string> = {
  Briefcase:
    '<rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>',
  GraduationCap:
    '<path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"></path><path d="M22 10v6"></path><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"></path>',
  ChevronRight: '<path d="m9 18 6-6-6-6"></path>',
};

interface ProjectLink {
  label: string;
  targetId: string;
}

interface Experience {
  role: string;
  company: string;
  location: string;
  period: string;
  iconName: string;
  description: string;
  projects?: ProjectLink[];
}

const experiences: Experience[] = [
  {
    role: "Desarrollador Web Independiente",
    company: "Freelance",
    location: "Remoto",
    period: "Ago 2023 — Feb 2026",
    iconName: "Briefcase",
    description:
      "Desarrollo soluciones tecnológicas enfocadas en automatización, integración de APIs y visualización de datos para negocios del sector retail e inmobiliario.",
    projects: [
      {
        label: "Automatización de reportes con API SUNAT",
        targetId: "project-facturatotal",
      },
      {
        label: "Chatbot de WhatsApp + Google Sheets",
        targetId: "project-bot-whatsapp",
      },
      {
        label: "E-commerce con Astro y Supabase",
        targetId: "project-muebleria-piero",
      },
      {
        label: "Lotizador interactivo con Leaflet",
        targetId: "project-residencial-valle-de-gracia",
      },
    ],
  },
  {
    role: "Instructor de Tecnología",
    company: "Infotec Moquegua",
    location: "Presencial",
    period: "Ene 2023 — Mar 2023",
    iconName: "GraduationCap",
    description:
      "Capacitación en programación y fundamentos de arquitectura de computadoras mediante metodología basada en proyectos.",
  },
];
---

<section id="experiencia" class="section-padding bg-card/30">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-14">
      <span class="font-mono text-primary text-sm">02.</span>
      <h2 class="font-display text-3xl md:text-4xl font-bold">Experiencia</h2>
      <div class="flex-1 h-px bg-border"></div>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div
        class="absolute left-[11px] top-1 bottom-1 w-px bg-border md:left-[11px]"
      >
      </div>

      <div class="space-y-14">
        {
          experiences.map((exp) => (
            <div class="relative pl-10">
              {/* Dot */}
              <div class="absolute left-0 top-1 w-[23px] h-[23px] rounded-full border-2 border-primary bg-background z-10 flex items-center justify-center">
                <div class="w-2 h-2 rounded-full bg-primary" />
              </div>

              {/* Period badge */}
              <div class="flex items-center gap-3 mb-2 flex-wrap">
                <span class="font-mono text-xs text-primary bg-primary/10 border border-primary/20 px-2.5 py-0.5 rounded-full">
                  {exp.period}
                </span>
                <span class="text-muted-foreground text-xs font-mono">
                  {exp.location}
                </span>
              </div>

              {/* Role & Company */}
              <h3 class="font-display text-xl md:text-2xl font-semibold mb-0.5">
                {exp.role}
              </h3>
              <p class="text-muted-foreground text-sm font-medium mb-3">
                {exp.company}
              </p>

              {/* Description */}
              <p class="text-muted-foreground text-sm leading-relaxed mb-4 max-w-2xl">
                {exp.description}
              </p>

              {/* Project links */}
              {exp.projects && (
                <div class="space-y-1.5">
                  <span class="font-mono text-xs text-muted-foreground uppercase tracking-wider">
                    Proyectos desarrollados
                  </span>
                  <ul class="space-y-1 mt-2">
                    {exp.projects.map((proj) => (
                      <li>
                        <button
                          data-target={proj.targetId}
                          class="scroll-to-project group/link flex items-center gap-2 text-sm text-foreground/80 hover:text-primary transition-colors duration-200 py-0.5"
                        >
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="text-primary/60 group-hover/link:translate-x-0.5 transition-transform"
                            set:html={icons.ChevronRight}
                          />
                          <span class="relative after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-primary after:transition-all after:duration-300 group-hover/link:after:w-full">
                            {proj.label}
                          </span>
                        </button>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".scroll-to-project").forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetId = (btn as HTMLElement).dataset.target;
      if (!targetId) return;

      const el = document.getElementById(targetId);
      if (!el) return;

      el.scrollIntoView({ behavior: "smooth", block: "center" });

      // Highlight effect after scroll
      setTimeout(() => {
        el.classList.add(
          "ring-2",
          "ring-primary/60",
          "shadow-[0_0_20px_hsl(172_66%_50%/0.25)]",
        );
        el.style.transition = "box-shadow 0.3s, ring 0.3s";

        setTimeout(() => {
          el.classList.remove(
            "ring-2",
            "ring-primary/60",
            "shadow-[0_0_20px_hsl(172_66%_50%/0.25)]",
          );
        }, 1200);
      }, 600);
    });
  });
</script>
