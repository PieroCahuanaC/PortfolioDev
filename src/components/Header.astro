---
const navItems = [
  { label: "Proyectos", href: "#proyectos" },
  { label: "Experiencia", href: "#experiencia" },
  { label: "Sobre mí", href: "#sobre-mi" },
  { label: "Certificaciones", href: "#certificaciones" },
  { label: "Stack", href: "#stack" },
];
---

<nav
  class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-xl border-b border-border"
>
  <div
    class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 flex items-center justify-between h-16"
  >
    <a
      href="#"
      class="font-display text-xl font-bold text-primary tracking-tight"
    >
      {"<dev />"}
    </a>

    <!-- Desktop -->
    <ul class="hidden md:flex items-center gap-8">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="font-display text-base text-muted-foreground hover:text-primary transition-colors duration-200"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Social icons (Desktop) -->
    <div class="hidden md:flex items-center gap-4">
      <a
        href="https://github.com/PieroCahuanaC"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-primary transition-colors"
        aria-label="GitHub"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path>
          <path d="M9 18c-4.51 2-5-2-7-2"></path>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/piero-anthony-cahuana-cabrera-57b113323/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-primary transition-colors"
        aria-label="LinkedIn"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path>
          <rect width="4" height="12" x="2" y="9"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </a>
      <div class="w-px h-6 bg-border mx-2"></div>
      <a
        href="https://drive.google.com/file/d/1GR7KO14z45U1kabJGcj-4uL_ffKu65-L/view?usp=sharing"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-primary/10 text-primary border border-primary/20 px-4 py-1.5 rounded-md text-sm font-mono hover:bg-primary/20 transition-all duration-300"
      >
        CV
      </a>
    </div>

    <!-- Mobile toggle -->
    <button
      id="menu-toggle"
      class="md:hidden text-foreground"
      aria-label="Toggle menu"
    >
      <svg
        id="icon-menu"
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="4" x2="20" y1="12" y2="12"></line>
        <line x1="4" x2="20" y1="6" y2="6"></line>
        <line x1="4" x2="20" y1="18" y2="18"></line>
      </svg>
      <svg
        id="icon-close"
        class="hidden"
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M18 6 6 18"></path>
        <path d="M6 6 18 18"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden bg-background/95 backdrop-blur-xl border-b border-border animate-fade-in hidden"
  >
    <ul class="flex flex-col px-6 py-4 gap-4">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="mobile-link font-display text-base text-muted-foreground hover:text-primary transition-colors"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    iconMenu?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
  });

  // Cerrar menú al hacer click en un enlace
  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      iconMenu?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>
