---
const navItems = [
  { label: "Proyectos", href: "#proyectos" },
  { label: "Experiencia", href: "#experiencia" },
  { label: "Sobre mí", href: "#sobre-mi" },
  { label: "Certificaciones", href: "#certificaciones" },
  { label: "Stack", href: "#stack" },
];
---

<nav
  class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-xl border-b border-border"
>
  <div
    class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 flex items-center justify-between h-16"
  >
    <a
      href="#"
      class="font-display text-xl font-bold text-primary tracking-tight"
    >
      {"<dev />"}
    </a>

    <!-- Desktop -->
    <ul class="hidden md:flex items-center gap-8">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="font-display text-base text-muted-foreground hover:text-primary transition-colors duration-200"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile toggle -->
    <button
      id="menu-toggle"
      class="md:hidden text-foreground"
      aria-label="Toggle menu"
    >
      <svg
        id="icon-menu"
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="4" x2="20" y1="12" y2="12"></line>
        <line x1="4" x2="20" y1="6" y2="6"></line>
        <line x1="4" x2="20" y1="18" y2="18"></line>
      </svg>
      <svg
        id="icon-close"
        class="hidden"
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M18 6 6 18"></path>
        <path d="M6 6 18 18"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden bg-background/95 backdrop-blur-xl border-b border-border animate-fade-in hidden"
  >
    <ul class="flex flex-col px-6 py-4 gap-4">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="mobile-link font-display text-base text-muted-foreground hover:text-primary transition-colors"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    iconMenu?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
  });

  // Cerrar menú al hacer click en un enlace
  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      iconMenu?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>
